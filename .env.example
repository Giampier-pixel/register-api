# Conexión a MongoDB
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/

# Secreto para firmar los JWT
JWT_SECRET=
# Vida del token
JWT_EXPIRES_IN=1h

# Orígenes permitidos para CORS (coma-separados). En producción, la URL de
# Vercel, p. ej. https://register-web.vercel.app  (sin barra final).
# Si se deja vacío, se aceptan todos los orígenes.
CORS_ORIGIN=

# Puerto. En local opcional (por defecto 3000). En Render NO lo definas:
# la plataforma inyecta PORT automáticamente.
PORT=

# Administrador inicial (npm run seed)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NOMBRE=
